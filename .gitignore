# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Build and packaging artifacts
build/
dist/
site/
*.egg-info/
.eggs/
pip-wheel-metadata/

# OS/editor noise
.DS_Store
.idea/
.vscode/

# Local runtime data
# Keep shareable workspace outputs (papers/artifacts/summary/topic),
# but ignore machine-local runtime files.
workspace/**/index.sqlite3
workspace/**/logs/
workspace/**/logs/**
